# ========================================
# 智选 - 环境变量配置
# 
# 使用说明：
# 1. 复制本文件，重命名为 .env
# 2. 把 "your_api_key_here" 替换成你的真实 API Key
# 3. 至少配置一个国内模型的 API Key 即可运行
#
# 国内模型无需翻墙，注册即用，大部分有免费额度！
# ========================================

# ==================== 国内模型 API Key（推荐）====================

# 阿里云百炼 API Key（通义千问 Qwen 系列）
# 获取方式：https://dashscope.aliyun.com/ → 注册 → API Key管理 → 创建
# 新用户赠送 100万 tokens 免费额度！
# 价格：qwen-turbo 约0.002元/千token，超便宜
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek API Key
# 获取方式：https://platform.deepseek.com/ → 注册 → API Keys → Create
# 充$2能用很久，推理能力极强
# 价格：deepseek-chat 约0.001元/千token，比OpenAI便宜95%
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 智谱AI API Key（GLM 系列，清华系）
# 获取方式：https://open.bigmodel.cn/ → 注册 → API Keys
# 新用户有免费额度，glm-4-flash 超便宜
# 价格：glm-4-flash 约0.0001元/千token，白菜价！
ZHIPU_API_KEY=your_zhipu_api_key_here

# 月之暗面 API Key（Kimi，长文本能力强）
# 获取方式：https://platform.moonshot.cn/ → 注册 → API Keys
# 新用户有免费额度，支持8K/32K/128K上下文
# 价格：moonshot-v1-8k 约0.012元/千token
MOONSHOT_API_KEY=your_moonshot_api_key_here

# ==================== 国外模型 API Key（可选）====================
# 如果你有这些Key也可以配上，没有也不影响使用

# OpenAI API Key（GPT-4o、GPT-4o-mini）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key（Claude 系列）
# 获取方式：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ==================== 可选配置 ====================

# 评委模型（用来评估输出质量，默认用国内模型 qwen-plus）
# 可选值：qwen-plus / deepseek-chat / glm-4-plus / gpt-4o-mini（需要OpenAI Key）
JUDGE_MODEL=qwen-plus

# 评估维度权重（加起来 = 1.0）
WEIGHT_COST=0.3
WEIGHT_SPEED=0.2
WEIGHT_QUALITY=0.5

# Web服务端口
PORT=8000
